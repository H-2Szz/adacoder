{
  "name": "adaassist",
  "displayName": "AdaAssist",
  "description": "Programming assistant for code workflows in VS Code.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:adaassist.openChat",
    "onCommand:adaassist.openSettings",
    "onCommand:adaassist.openProfileConfig",
    "onCommand:adaassist.runWorkflow",
    "onCommand:adaassist.runFromSelection",
    "onView:adaassist.sidebarView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "adaassist.openChat",
        "title": "AdaAssist: Open Chat"
      },
      {
        "command": "adaassist.openSettings",
        "title": "AdaAssist: Open Settings"
      },
      {
        "command": "adaassist.openProfileConfig",
        "title": "AdaAssist: Open Profile Config File"
      },
      {
        "command": "adaassist.runWorkflow",
        "title": "AdaAssist: Open Chat"
      },
      {
        "command": "adaassist.runFromSelection",
        "title": "AdaAssist: Generate From Selection"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "adaassist.runFromSelection",
          "when": "editorHasSelection",
          "group": "navigation@100"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "adaassist-sidebar",
          "title": "AdaAssist",
          "icon": "media/adaassist.svg"
        }
      ]
    },
    "views": {
      "adaassist-sidebar": [
        {
          "id": "adaassist.sidebarView",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "AdaAssist",
      "properties": {
        "adaassist.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Python executable. Supports command (python3), absolute path, relative path, ${workspaceFolder} and ${extensionPath}."
        },
        "adaassist.backendPath": {
          "type": "string",
          "default": "backend/main.py",
          "description": "Path to the FastAPI backend entry file. Supports absolute path, relative path, ${workspaceFolder} and ${extensionPath}."
        },
        "adaassist.backendHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host used when starting the bundled FastAPI backend."
        },
        "adaassist.backendPort": {
          "type": "number",
          "default": 8765,
          "description": "Port used when starting the bundled FastAPI backend."
        },
        "adaassist.bridgePath": {
          "type": "string",
          "default": "backend/bridge.py",
          "description": "Legacy bridge.py path kept for compatibility with older workspace settings."
        },
        "adaassist.profileConfigPath": {
          "type": "string",
          "default": ".vscode/adaassist-profiles.json",
          "description": "Path to profile JSON config file. Supports absolute path, relative path, ${workspaceFolder} and ${extensionPath}."
        },
        "adaassist.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Default LLM base_url sent to backend."
        },
        "adaassist.model": {
          "type": "string",
          "default": "gpt-5.4",
          "description": "Default model name sent to backend."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
